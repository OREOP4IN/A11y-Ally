{
  "manifest_version": 3,
  "name": "A11y-Ally",
  "version": "1.0",
  "description": "Enhances accessibility by fixing contrast issues based on Pa11y report",
  "icons": {
    "16": "img/logo_16.png",
    "32": "img/logo_32.png",
    "48": "img/logo_48.png",
    "128": "img/logo_128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/logo_16.png",
      "32": "img/logo_32.png",
      "48": "img/logo_48.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/OpenDyslexic-Regular.woff2"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Z", "mac": "Command+Shift+Y" },
      "description": "Buka panel A11y-Ally"
    },
    "toggle-auto-fix": {
      "suggested_key": { "default": "Alt+A", "mac": "Alt+A" },
      "description": "Toggle Auto Fix"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}